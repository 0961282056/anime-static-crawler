# Copy this file to .env for local crawling. Never commit .env.

# Required only when running the crawler or retention dry-run
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional operational notifications
DISCORD_WEBHOOK_URL=
SENTRY_DSN=
SENTRY_BROWSER_DSN=

# Runtime identity and behavior
APP_ENVIRONMENT=development
CRAWLER_USER_AGENT=anime-static-crawler/2.0 (+https://github.com/YOUR_ACCOUNT/YOUR_REPOSITORY)
CRAWLER_MAX_WORKERS=4
REQUEST_TIMEOUT_SECONDS=15
IMAGE_TIMEOUT_SECONDS=15
IMAGE_MAX_BYTES=10485760
IMAGE_ALLOWED_HOSTS=static.acgsecrets.hk

# Data quality gates
QUALITY_MIN_COUNT_RATIO=0.70
QUALITY_MAX_PARSE_FAILURE_RATIO=0
QUALITY_MAX_FALLBACK_ID_RATIO=0
CLOUDINARY_QUOTA_LIMIT_PERCENT=90

# Build-only settings
BUILD_ONLY=false
BUILD_VERSION=
OUTPUT_DIR=
